{
  "manifest_version": 3,
  "name": "Bet Bot — DK Sync",
  "version": "1.0",
  "description": "Syncs your DraftKings bets to Bet Bot in real time",
  "permissions": ["storage", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://*.draftkings.com/*",
    "https://*.up.railway.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.draftkings.com/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://*.draftkings.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bet Bot DK Sync"
  }
}
